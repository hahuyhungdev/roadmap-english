{
  "openapi": "3.1.0",
  "info": {
    "title": "Roadmap English API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/lesson-notes": {
      "get": {
        "operationId": "getLessonNote",
        "parameters": [
          {
            "name": "sessionSlug",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lesson note",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LessonNote"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "upsertLessonNote",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LessonNoteUpsertRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Saved lesson note",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LessonNote"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LessonNote": {
        "type": "object",
        "required": [
          "sessionSlug",
          "content",
          "updatedAt"
        ],
        "properties": {
          "sessionSlug": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "updatedAt": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "LessonNoteUpsertRequest": {
        "type": "object",
        "required": [
          "sessionSlug",
          "content"
        ],
        "properties": {
          "sessionSlug": {
            "type": "string"
          },
          "content": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    }
  }
}
